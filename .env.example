# Lensa Insignia — Environment Variables
# Copy this file to .env and fill in your values

# Supabase — required for auth, database, and file storage
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Site URL — used for sitemap.xml generation and canonical URLs
# Set to your production domain when deploying (e.g. https://yoursite.com)
SITE_URL=http://localhost:3000

# GEMINI_API_KEY: Required for Gemini AI API calls (optional)
# GEMINI_API_KEY=""
