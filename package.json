    "@vitejs/plugin-react": "^5.0.4",
    "compression": "^1.8.1",
    "date-fns": "^4.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^9.22.2",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "next-mdx-remote": "^6.0.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^7.14.1",
    "sirv": "^3.0.2",
    "vite": "^6.2.0"
  },
